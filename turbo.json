{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
      "build": {
          "dependsOn": ["^generate", "^build"],
          "inputs": ["$TURBO_DEFAULT$"],
          "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
      },
      "generate": {
          "dependsOn": ["^generate"]
      },
      "db:migrate:deploy": {
          "cache": false
      },
      "db:seed": {
          "cache": false
      },
      "dev": {
          "cache": false,
          "persistent": true
      },
      "lint": {}
  },
  "globalEnv": [
    "DATABASE_URL",
    "POSTGRES_URL",
    "POSTGRES_URL_NON_POOLING",
    "POSTGRES_USER",
    "POSTGRES_HOST",
    "POSTGRES_PASSWORD",
    "POSTGRES_DATABASE",
    "POSTGRES_URL_NO_SSL",
    "POSTGRES_PRISMA_URL",
    "PGUSER",
    "PGHOST",
    "PGHOST_UNPOOLED",
    "PGPASSWORD",
    "PGDATABASE",
    "DATABASE_URL_UNPOOLED",
    "CLOUDINARY_API_KEY",
    "CLOUDINARY_API_SECRET",
    "RESEND_API_KEY",
    "CLERK_SECRET_KEY"
  ]
}
